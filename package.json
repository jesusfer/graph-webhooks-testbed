{
    "name": "graph-webhooks-testbed",
    "version": "1.0.0",
    "description": "Web application to test Microsoft Graph subscriptions with webhook notifications",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node src/server.ts",
        "format": "prettier --write \"src/**/*.ts\" \"public/**/*.html\" \".github/**/*.yml\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"public/**/*.html\"",
        "build:frontend": "esbuild src/frontend/app.ts --bundle --outfile=public/js/app.js --minify --sourcemap --target=es2020 --format=esm",
        "build:all": "npm run build && npm run build:frontend",
        "dev:back": "nodemon --exec ts-node src/server.ts",
        "dev:front": "esbuild src/frontend/app.ts --bundle --outfile=public/js/app.js --sourcemap --target=es2020 --format=esm --watch",
        "dev:watch": "concurrently \"nodemon --exec ts-node src/server.ts\" \"esbuild src/frontend/app.ts --bundle --outfile=public/js/app.js --sourcemap --target=es2020 --format=esm --watch\""
    },
    "dependencies": {
        "@azure/data-tables": "^13.3.2",
        "@azure/identity": "^4.13.0",
        "@azure/msal-browser": "^5.3.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-history-api-fallback": "^2.2.1",
        "express-session": "^1.19.0",
        "jsonwebtoken": "^9.0.3",
        "jwks-rsa": "^3.2.2",
        "node-forge": "^1.3.3",
        "uuid": "^13.0.0",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.18.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.10.13",
        "@types/node-forge": "^1.3.14",
        "@types/ws": "^8.18.1",
        "concurrently": "^9.2.1",
        "esbuild": "^0.27.3",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
