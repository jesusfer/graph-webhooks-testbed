{
    "name": "graph-webhooks-testbed",
    "version": "1.0.0",
    "private": true,
    "description": "Web application to test Microsoft Graph subscriptions with webhook notifications",
    "scripts": {
        "start": "cd backend && node dist/server.js",
        "build": "npm run build:backend && npm run build:frontend",
        "build:backend": "cd backend && npm run build",
        "build:frontend": "cd frontend && npm run build",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "cd backend && npm run dev",
        "dev:frontend": "cd frontend && npm run dev",
        "install:all": "cd backend && npm install && cd ../frontend && npm install",
        "format": "prettier --write \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\" \"frontend/public/**/*.html\" \".github/**/*.yml\"",
        "format:check": "prettier --check \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\" \"frontend/public/**/*.html\""
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "prettier": "^3.8.3"
    }
}
