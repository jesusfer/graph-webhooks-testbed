# Entra ID App Registration
ENTRA_CLIENT_ID=your-client-id-here
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_REDIRECT_URI=http://localhost:3000

# Azure Storage Account
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-random-secret

# Graph API (optional - base URL for webhook notifications)
# devtunnel host -p 3000 --allow-anonymous
# ngrok http 3000
GRAPH_NOTIFICATION_URL=https://your-public-url/api/webhook

# Encryption certificate for rich notifications (optional, base64-encoded)
# Use: openssl x509 -in cert.pem -outform DER | base64 -w0
GRAPH_ENCRYPTION_CERTIFICATE=

# PFX (PKCS#12) containing the private key for decrypting rich notification payloads
# Use: base64 -w0 cert.pfx
GRAPH_ENCRYPTION_PFX=
# Password for the PFX file (leave empty if none)
GRAPH_ENCRYPTION_PFX_PASSWORD=
